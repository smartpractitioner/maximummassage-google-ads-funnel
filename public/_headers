/reports/*
  X-Robots-Tag: noindex, nofollow

# Self-hosted woff2 files are content-addressed by filename and never
# rewritten, so cache them aggressively at the browser AND CF edge.
/fonts/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Images use fixed (non-hashed) filenames, so we can't mark them immutable. The
# 1-day TTL we started with was flagged by BOTH GTmetrix ("serve static assets with
# an efficient cache policy", 24h) and Pingdom ("add Expires headers"), and the hero
# has now settled, so raise it to 30 days. Repeat visits and the edge cache both hold
# far longer, which is what those audits want.
# ⚠️ Trade-off: a replaced image keeps serving from cache for up to 30 days. If you
# swap an image, either rename it or append a ?v= query in the HTML to bust it —
# do NOT rely on the TTL expiring.
/images/*
  Cache-Control: public, max-age=2592000
